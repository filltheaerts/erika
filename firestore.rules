// ============================================================
// ERIKA — Firestore Security Rules (Firebase Auth)
// ============================================================
//
// [적용 방법]
// 1. Firebase Console → Firestore Database → 규칙(Rules) 탭
// 2. 아래 내용을 복사하여 붙여넣기
// 3. "게시" 클릭
//
// [규칙 설명]
// - 인증된 사용자만 데이터 접근 가능
// - admin(erika@erika-board.com)만 게시물 삭제 및 설정 수정 가능
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: 인증된 사용자인지 확인
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: admin 사용자인지 확인
    function isAdminUser() {
      return isSignedIn() && request.auth.token.email == 'erika@erika-board.com';
    }

    // posts 컬렉션
    match /posts/{postId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isAdminUser();

      // comments 서브컬렉션
      match /comments/{commentId} {
        allow read, create, delete: if isSignedIn();
      }
    }

    // settings 컬렉션 (CMS 콘텐츠)
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    // 그 외 모든 문서 — 접근 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
